# ── Database (Supabase free tier) ──────────────────────────────────────────
# 1. Create a free project at supabase.com (any region; EU/UK recommended —
#    see docs/PRD.md §11.1 on data residency for vulnerable-person data).
# 2. Dashboard -> Connect -> ORMs -> Prisma gives you both strings below.
#
# App runtime — Transaction pooler (PgBouncer), port 6543. Used by the
# running app (src/lib/prisma.ts) via the @prisma/adapter-pg driver adapter.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI tooling (migrate, studio, introspect) — Session pooler, port
# 5432. NOTE: use the Session pooler, NOT "Direct connection"
# (db.<ref>.supabase.co) — direct connections are IPv6-only on the free tier
# and fail on most home/office networks. The session pooler is IPv4 and
# supports the DDL migrations need.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"

# If your Supabase password contains special characters (@ : / % etc.),
# URL-encode them, or regenerate an alphanumeric password from the dashboard
# — this is the #1 setup failure with Supabase + Prisma.

# ── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: npx auth secret   (writes to .env.local — copy the value here)
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# ── Magic-link email (production only — leave blank for local dev) ─────────
# Auth.js's built-in Resend provider; get a key at resend.com.
AUTH_RESEND_KEY=""
EMAIL_FROM="Dreamers CRM <login@example.com>"
